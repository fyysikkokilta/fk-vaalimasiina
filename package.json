{
  "name": "fk-vaalimasiina",
  "version": "1.0.0",
  "description": "Electronic voting system for the Guild of Physics",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-next-config-strip-types",
    "build": "next build --experimental-next-config-strip-types",
    "start": "next start --experimental-next-config-strip-types",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typegen": "next typegen",
    "generate-election": "tsx ./tests/fixtures/generate-election.ts",
    "typecheck": "tsgo --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx ./src/db/migrate.ts",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/helpers": "^0.4.0",
    "@dnd-kit/react": "^0.4.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "1.0.0-rc.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "next-safe-action": "^8.5.2",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-email": "^6.1.1",
    "s3mini": "^0.9.4",
    "seedrandom": "^3.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@typescript/native-preview": "7.0.0-dev.20260511.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "1.0.0-rc.2",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.14",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "packageManager": "pnpm@11.1.1"
}
