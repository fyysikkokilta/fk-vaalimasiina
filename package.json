{
  "name": "fk-vaalimasiina",
  "version": "1.0.0",
  "description": "Electronic voting system for the Guild of Physics",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "next dev --experimental-next-config-strip-types",
    "build": "next build --experimental-next-config-strip-types",
    "start": "next start --experimental-next-config-strip-types",
    "lint": "oxlint .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "typegen": "next typegen",
    "generate-election": "tsx ./tests/fixtures/generate-election.ts",
    "type:check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx ./src/db/migrate.ts",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@react-email/components": "^1.0.9",
    "@t3-oss/env-nextjs": "^0.13.10",
    "csv-parse": "^6.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "1.0.0-beta.18-7eb39f0",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-intl": "^4.8.3",
    "next-safe-action": "^8.1.8",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.2",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "s3mini": "^0.9.1",
    "seedrandom": "^3.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "1.0.0-beta.18-7eb39f0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "postcss": "^8.5.8",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "simple-git-hooks"
    ]
  }
}
